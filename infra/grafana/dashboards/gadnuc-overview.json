{
  "title": "Gadnuc Platform Overview",
  "uid": "gadnuc-overview",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "Request Rate — inventory-server",
      "type": "timeseries",
      "gridPos": { "x": 0,  "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(http_request_duration_seconds_count{service='inventory-server'}[2m])) by (method,route)", "legendFormat": "{{method}} {{route}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 2, "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service='inventory-server'}[2m])) by (le,route)) * 1000", "legendFormat": "p95 {{route}}" }],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 3, "title": "Requests by Tenant (top 10)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "topk(10, sum(rate(tenant_requests_total[2m])) by (tenant_slug))", "legendFormat": "{{tenant_slug}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4, "title": "5xx Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(http_request_duration_seconds_count{status_code=~'5..'}[2m])) by (service)", "legendFormat": "{{service}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "id": 5, "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 4, "h": 4 },
      "targets": [{ "expr": "ws_active_connections", "legendFormat": "WS Connections" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 1000 }] } } }
    },
    {
      "id": 6, "title": "Messages / 5m",
      "type": "stat",
      "gridPos": { "x": 4, "y": 16, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(messaging_messages_sent_total[5m]))" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } } }
    },
    {
      "id": 7, "title": "Stripe Checkout Sessions / 1h",
      "type": "stat",
      "gridPos": { "x": 8, "y": 16, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(stripe_checkout_sessions_total[1h]))" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "purple", "mode": "fixed" } } }
    },
    {
      "id": 8, "title": "DB Pool — inventory-server",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 4, "h": 4 },
      "targets": [{ "expr": "db_pool_total_connections{service='inventory-server'}" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9, "title": "DB Pool Idle",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 4, "h": 4 },
      "targets": [{ "expr": "db_pool_idle_connections{service='inventory-server'}" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10, "title": "DB Pool Waiting",
      "type": "stat",
      "gridPos": { "x": 20, "y": 16, "w": 4, "h": 4 },
      "targets": [{ "expr": "db_pool_waiting_requests{service='inventory-server'}" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 11, "title": "Messages per Tenant (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(messaging_messages_sent_total[5m])) by (tenant_slug)", "legendFormat": "{{tenant_slug}}" }],
      "fieldConfig": { "defaults": { "unit": "mps" } }
    },
    {
      "id": 12, "title": "Stripe Sessions per Tenant",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum(rate(stripe_checkout_sessions_total[10m])) by (tenant_slug, mode)", "legendFormat": "{{tenant_slug}} ({{mode}})" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 13, "title": "Heap Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes{service='inventory-server'} / 1024 / 1024", "legendFormat": "inventory-server heap" },
        { "expr": "nodejs_heap_size_used_bytes{service='server-manager'}  / 1024 / 1024", "legendFormat": "server-manager heap" }
      ],
      "fieldConfig": { "defaults": { "unit": "megabytes" } }
    },
    {
      "id": 14, "title": "Active WebSocket Connections (history)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [{ "expr": "ws_active_connections", "legendFormat": "Active WS" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "teal", "mode": "fixed" } } }
    }
  ]
}
