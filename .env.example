# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gadnuc:password@localhost:5432/gadnuc

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-very-long-random-secret-at-least-32-chars
# Used to AES-256-GCM encrypt TOTP secrets at rest — generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=replace-with-a-very-long-random-secret-at-least-32-chars

# ─── Platform ────────────────────────────────────────────────────────────────
PLATFORM_DOMAIN=gadnuc.io
NODE_ENV=development

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── DigitalOcean ────────────────────────────────────────────────────────────
DO_TOKEN=dop_v1_...
DO_SPACES_KEY=...
DO_SPACES_SECRET=...
DO_SPACES_BUCKET=gadnuc-media
DO_SPACES_REGION=nyc3

# ─── Storefront ──────────────────────────────────────────────────────────────
INVENTORY_SERVER_URL=http://localhost:3001

# ─── Ports ───────────────────────────────────────────────────────────────────
# inventory-server: 3001
# server-manager:   3002
# storefront:       3000
