# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gadnuc:password@localhost:5432/gadnuc
# Read replica URL — omit to fall back to primary pool (fine for dev/staging)
# In production: point to DO Managed Postgres standby read-only connection string
DATABASE_REPLICA_URL=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-very-long-random-secret-at-least-32-chars
# Used to AES-256-GCM encrypt TOTP secrets at rest — generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=replace-with-a-very-long-random-secret-at-least-32-chars

# ─── Platform ────────────────────────────────────────────────────────────────
PLATFORM_DOMAIN=gadnuc.io
NODE_ENV=development

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── DigitalOcean ────────────────────────────────────────────────────────────
DO_TOKEN=dop_v1_...
DO_SPACES_KEY=...
DO_SPACES_SECRET=...
DO_SPACES_BUCKET=gadnuc-media
DO_SPACES_REGION=nyc3

# ─── Backups ──────────────────────────────────────────────────────────────────
# Bucket used by infra/scripts/backup-tenant.sh (can differ from media bucket)
BACKUP_RETENTION_DAYS=30
# Strongly recommended — generate with: openssl rand -base64 32
BACKUP_PASSPHRASE=

# ─── Storefront ──────────────────────────────────────────────────────────────
INVENTORY_SERVER_URL=http://localhost:3001

# ─── Observability ───────────────────────────────────────────────────────────
# Prometheus scrapes GET /metrics on each service (no auth — restrict via network ACL)
# Grafana provisioning: infra/grafana/

# ─── Ports ───────────────────────────────────────────────────────────────────
# inventory-server: 3001
# server-manager:   3002
# storefront:       3000
# prometheus:       9090  (infra/grafana/prometheus.yml)
# grafana:          3003
